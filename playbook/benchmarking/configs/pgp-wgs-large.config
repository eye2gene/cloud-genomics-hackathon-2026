// Custom config for PGP-UK whole genome FASTQs (40-50 GB per file)
// The default sarek memory for FASTP/FASTQC (4 GB) is too low for
// the AWS CLI multipart S3 download of files this large.
// See: https://github.com/aws/aws-cli/issues/2390

env.SENTIEON_LICENSE = '/tmp/sentieon.lic'

process {
    queue = 'Spot-afonso-nfbatch'

    // Retry on OOM, spot interruption, and transient failures
    errorStrategy = { task.exitStatus in [1, 137, 143, 255] ? 'retry' : 'finish' }
    maxRetries = 3

    withName: 'FASTQC' {
        cpus = { 4 * task.attempt }
        memory = { 64.GB * task.attempt }
    }
    withName: 'FASTP' {
        cpus = { 12 * task.attempt }
        memory = { 128.GB * task.attempt }
    }
    withName: 'GATK4_BASERECALIBRATOR' {
        memory = { 64.GB * task.attempt }
    }
    withName: 'MOSDEPTH' {
        memory = { 32.GB * task.attempt }
    }
    withName: 'SAMTOOLS_STATS' {
        memory = { 16.GB * task.attempt }
    }
    withName: 'SENTIEON.*' {
        beforeScript = '/opt/aws-cli/bin/aws s3 cp s3://afonso-afonso-nfbatch-246089461721/benchmarks/configs/sentieon.lic /tmp/sentieon.lic 2>/dev/null || true'
    }
}

report {
    overwrite = true
}
timeline {
    overwrite = true
}
tower {
    enabled = true
    // Set TOWER_ACCESS_TOKEN env var on head node container overrides
}
