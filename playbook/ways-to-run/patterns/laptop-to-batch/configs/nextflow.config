// Nextflow config for Laptop to AWS Batch pattern
// Adjust queue name, region, and bucket to match your deployment

process {
    executor = 'awsbatch'
    queue = 'your-job-queue-name'
}

aws {
    region = 'eu-west-2'
    batch {
        cliPath = '/home/ec2-user/miniconda/bin/aws'
    }
}

workDir = 's3://your-bucket-name/work'
